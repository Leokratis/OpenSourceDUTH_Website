---
import { testimonials } from "@/config/landing";
import { Image } from "astro:assets";
import HeaderSection from "./header-section.astro";
---

<section>
  <div class="mx-auto flex max-w-7xl flex-col gap-10 py-32 sm:gap-y-16 px-4 sm:px-6 lg:px-8">
    <HeaderSection
      label="Our Team"
      title="What our clients are sharing."
      subtitle="The students behind the OpenSourceDUTH team."
    />

    <div class="column-1 gap-8 space-y-8 md:columns-2 lg:columns-3">
      {
        testimonials.map((item) => (
          <div class="break-inside-avoid mb-8">
            <div class="relative rounded-xl border bg-muted/25 min-h-[200px]">
              <div class="flex flex-col px-6 py-8">
                <div>
                  <div class="relative mb-6 flex items-center gap-4">
                    <span class="relative inline-flex size-16 shrink-0 items-center justify-center rounded-full text-base">
                      <Image
                        width={100}
                        height={100}
                        class="size-full rounded-full border"
                        src={item.image || "/placeholder.svg"}
                        alt={item.name}
                      />
                    </span>
                    <div>
                      <p class="text-base font-semibold text-foreground">
                        {item.name}
                      </p>
                      <p class="text-sm text-muted-foreground">{item.job}</p>
                    </div>
                  </div>
                  <q class="text-muted-foreground text-base">{item.review}</q>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

